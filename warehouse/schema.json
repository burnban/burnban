{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://burnban.dev/schemas/telemetry/v1.json",
  "title": "Burnban content-free telemetry event v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version", "request_id", "observed_at", "provider",
    "identity_confidence", "input_tokens", "output_tokens",
    "cache_read_tokens", "cache_write_tokens", "cache_write_1h_tokens",
    "cost_usd", "latency_ms", "http_status", "streamed",
    "usage_confidence", "pricing_state", "incomplete", "enforcement_gap",
    "retry_count", "downshifted"
  ],
  "properties": {
    "schema_version": {"const": "burnban.telemetry.v1"},
    "request_id": {"type": "integer", "minimum": 1},
    "observed_at": {"type": "string", "format": "date-time"},
    "provider": {"$ref": "#/$defs/label"},
    "model": {"$ref": "#/$defs/label"},
    "agent": {"$ref": "#/$defs/label"},
    "route": {"$ref": "#/$defs/label"},
    "service_tier": {"$ref": "#/$defs/label"},
    "geo": {"$ref": "#/$defs/label"},
    "principal": {"$ref": "#/$defs/label"},
    "trusted_principal": {"$ref": "#/$defs/label"},
    "service_account": {"$ref": "#/$defs/label"},
    "identity_tenant": {"$ref": "#/$defs/label"},
    "project": {"$ref": "#/$defs/label"},
    "cost_center": {"$ref": "#/$defs/label"},
    "identity_device_id": {"$ref": "#/$defs/label"},
    "identity_confidence": {
      "enum": ["authenticated", "self_reported", "unverified"]
    },
    "input_tokens": {"$ref": "#/$defs/non_negative_integer"},
    "output_tokens": {"$ref": "#/$defs/non_negative_integer"},
    "cache_read_tokens": {"$ref": "#/$defs/non_negative_integer"},
    "cache_write_tokens": {"$ref": "#/$defs/non_negative_integer"},
    "cache_write_1h_tokens": {"$ref": "#/$defs/non_negative_integer"},
    "cost_usd": {"type": "number", "minimum": 0, "maximum": 1000000000000},
    "latency_ms": {"$ref": "#/$defs/non_negative_integer"},
    "http_status": {"type": "integer", "minimum": 0, "maximum": 999},
    "streamed": {"type": "boolean"},
    "usage_confidence": {"$ref": "#/$defs/label"},
    "pricing_state": {"$ref": "#/$defs/label"},
    "cost_source": {"$ref": "#/$defs/label"},
    "cost_source_ref": {"$ref": "#/$defs/label"},
    "cost_effective_from": {"type": "string", "format": "date"},
    "cost_valid_through": {"type": "string", "format": "date"},
    "cost_confidence": {"$ref": "#/$defs/label"},
    "incomplete": {"type": "boolean"},
    "enforcement_gap": {"type": "boolean"},
    "decision_id": {"$ref": "#/$defs/non_negative_integer"},
    "decision": {"$ref": "#/$defs/label"},
    "decision_admitted": {"type": "boolean"},
    "policy_name": {"$ref": "#/$defs/label"},
    "policy_namespace": {"$ref": "#/$defs/label"},
    "policy_version": {"$ref": "#/$defs/non_negative_integer"},
    "policy_digest": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "policy_mode": {"$ref": "#/$defs/label"},
    "policy_confidence": {"$ref": "#/$defs/label"},
    "retry_count": {"$ref": "#/$defs/non_negative_integer"},
    "downshifted": {"type": "boolean"},
    "downshift_from": {"$ref": "#/$defs/label"},
    "requested_provider": {"$ref": "#/$defs/label"},
    "requested_route": {"$ref": "#/$defs/label"},
    "downshift_action": {"enum": ["warn", "downshift"]},
    "downshift_rule": {"$ref": "#/$defs/label"},
    "downshift_trigger": {"$ref": "#/$defs/label"},
    "downshift_reason": {"$ref": "#/$defs/label"},
    "downshift_config_digest": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "downshift_source_estimated_usd": {"type": "number", "minimum": 0, "maximum": 1000000000000},
    "downshift_target_estimated_usd": {"type": "number", "minimum": 0, "maximum": 1000000000000}
  },
  "$defs": {
    "label": {"type": "string", "maxLength": 256},
    "non_negative_integer": {"type": "integer", "minimum": 0}
  }
}
